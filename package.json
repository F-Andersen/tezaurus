{
  "name": "tezaurus-tour",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:admin": "pnpm --filter admin build",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter api run prisma:generate",
    "db:migrate": "pnpm --filter api run prisma:migrate",
    "db:push": "pnpm --filter api run prisma:push",
    "db:studio": "pnpm --filter api run prisma:studio"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
