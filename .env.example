# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tezaurus_tour"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# SMTP (SendGrid/Mailgun/Gmail)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tezaurustour.com

# S3-compatible storage (AWS S3 / R2 / MinIO)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=tezaurus-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Captcha (Cloudflare Turnstile or reCAPTCHA)
CAPTCHA_SECRET_KEY=
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# Frontend URLs (for CORS)
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
